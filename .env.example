# Copy to `.env` for local dev. Jotform key from: https://www.jotform.com/myaccount/api
# Never commit real keys to a public repository.
VITE_JOTFORM_API_KEY=

# Optional: default is dev proxy to https://api.jotform.com (see vite.config.js) or public origin in production.
# VITE_JOTFORM_API_BASE=/jotform-api
